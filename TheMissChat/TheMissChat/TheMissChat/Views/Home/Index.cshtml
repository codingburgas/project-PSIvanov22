@{
    ViewData["Title"] = "Welcome";
}

<style>
    .old-paper {
        background: #f3e9d2;
        border: 2px solid #c2a878;
        padding: 40px;
        margin: 40px auto;
        max-width: 700px;
        box-shadow: 0 0 25px rgba(0,0,0,0.25);
        font-family: "Georgia", serif;
        color: #4b3a2f;
        border-radius: 6px;
        background-image: url('data:image/png;base64,iVBORw0KGgoAAAANSUhEUgAAAAEAAAABCAYAAAAfFcSJAAAADUlEQVQIW2P4//8/AwAI/AL+ZMhUlQAAAABJRU5ErkJggg==');
    }

    .old-title {
        font-size: 42px;
        font-weight: bold;
        text-align: center;
        margin-bottom: 10px;
        letter-spacing: 1px;
        color: #3b2a1e;
    }

    .old-subtitle {
        font-size: 20px;
        text-align: center;
        margin-bottom: 30px;
        color: #5a4636;
    }

    .old-button {
        display: block;
        margin: 0 auto;
        padding: 12px 25px;
        background: #8b6f47;
        color: #fff;
        border: 2px solid #5e472d;
        border-radius: 5px;
        font-size: 18px;
        text-decoration: none;
        font-family: "Georgia", serif;
        transition: 0.2s;
    }

    .old-button:hover {
        background: #a7895c;
        border-color: #4a3823;
        color: #fff;
    }
</style>

<div class="old-paper">
    <div class="old-title">Welcome to TheMissChat</div>

    <div class="old-subtitle">
        A timeless place where conversations unfold like pages in an ancient book.
    </div>

    <a href="/Chat/Index" class="old-button">Enter Chat Rooms</a>
</div>
